---
interface Props {
  chart: string;
}

const { chart } = Astro.props;
---

<div class="mermaid-container group my-6 flex cursor-pointer justify-center rounded-xl bg-gray-50 p-4 transition-shadow duration-200 hover:shadow-md dark:bg-transparent dark:p-0 [&_svg]:max-w-full [&_svg]:min-w-[min(100%,600px)]" title="Click to enlarge">
  <pre class="mermaid not-prose bg-transparent! p-0! text-lg" set:html={chart} />
</div>

<div id="mermaid-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/70 backdrop-blur-sm" role="dialog" aria-modal="true" aria-label="Enlarged diagram">
  <button id="mermaid-modal-close" class="absolute top-4 right-4 rounded-full bg-white/10 p-2 text-white transition-colors hover:bg-white/20" aria-label="Close">
    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
    </svg>
  </button>
  <div id="mermaid-modal-content" class="max-h-[90vh] w-[min(90vw,1200px)] overflow-auto rounded-2xl bg-white p-6 dark:bg-gray-900 [&_svg]:max-w-full"></div>
</div>

<script>
  // Heavy `mermaid` library is loaded lazily (dynamic import) only once a
  // diagram is about to scroll into view, so it stays out of the initial
  // critical request chain.
  type Mermaid = typeof import('mermaid').default;

  let mermaidPromise: Promise<Mermaid> | null = null;

  function loadMermaid(): Promise<Mermaid> {
    // Guard: dynamic import happens a single time, then is reused.
    if (!mermaidPromise) {
      mermaidPromise = import('mermaid').then((mod) => mod.default);
    }
    return mermaidPromise;
  }

  async function renderMermaid() {
    const mermaid = await loadMermaid();
    const isDark = document.documentElement.classList.contains('dark');
    // Restore original source before re-rendering
    const diagrams = document.querySelectorAll<HTMLElement>('.mermaid');
    diagrams.forEach((el) => {
      const source = el.dataset.source;
      if (source) {
        el.removeAttribute('data-processed');
        el.replaceChildren();
        el.insertAdjacentHTML('afterbegin', source);
      }
    });
    mermaid.initialize({
      startOnLoad: false,
      theme: isDark ? 'dark' : 'default',
    });
    mermaid.run({ querySelector: '.mermaid' });
  }

  function getModal() {
    return document.getElementById('mermaid-modal')!;
  }

  let triggerEl: HTMLElement | null = null;

  function openModal(svgHtml: string, trigger?: HTMLElement) {
    triggerEl = trigger ?? null;
    const modal = getModal();
    const content = document.getElementById('mermaid-modal-content')!;
    content.innerHTML = svgHtml;
    // Scale SVG to fill modal - remove fixed dimensions, use viewBox for scaling
    const svg = content.querySelector('svg');
    if (svg) {
      svg.removeAttribute('width');
      svg.style.maxWidth = 'none';
      svg.style.width = '100%';
      svg.style.height = 'auto';
      svg.style.maxHeight = '80vh';
    }
    modal.classList.remove('hidden');
    modal.classList.add('flex');
    document.body.style.overflow = 'hidden';
    document.getElementById('mermaid-modal-close')?.focus();
  }

  function closeModal() {
    const modal = getModal();
    modal.classList.add('hidden');
    modal.classList.remove('flex');
    document.getElementById('mermaid-modal-content')!.innerHTML = '';
    document.body.style.overflow = '';
    triggerEl?.focus();
    triggerEl = null;
  }

  let rendered = false;

  // Trigger the (lazy) initial render exactly once. Subsequent theme-toggle
  // re-renders go straight through renderMermaid() since mermaid is cached.
  function renderOnce() {
    if (rendered) return;
    rendered = true;
    renderMermaid();
  }

  function init() {
    // --- Setup that does NOT need the mermaid library runs immediately ---

    // Store original chart source for re-rendering on theme change
    document.querySelectorAll<HTMLElement>('.mermaid').forEach((el) => {
      if (!el.dataset.source) {
        el.dataset.source = el.innerHTML;
      }
    });

    // Click to enlarge
    document.querySelectorAll<HTMLElement>('.mermaid-container').forEach((container) => {
      container.addEventListener('click', () => {
        const svg = container.querySelector('svg');
        if (svg) openModal(svg.outerHTML, container);
      });
    });

    // Close modal
    document.getElementById('mermaid-modal-close')!.addEventListener('click', closeModal);
    getModal().addEventListener('click', (e) => {
      if (e.target === getModal()) closeModal();
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeModal();
    });

    // Watch for dark class toggle on <html> (debounced to prevent double-renders).
    // If the theme flips before any diagram has rendered yet, renderMermaid()
    // would pull in mermaid prematurely - so only re-render once initial render
    // has been triggered.
    let themeTimer: number;
    new MutationObserver(() => {
      if (!rendered) return;
      clearTimeout(themeTimer);
      themeTimer = window.setTimeout(renderMermaid, 100);
    }).observe(document.documentElement, {
      attributes: true,
      attributeFilter: ['class'],
    });

    // --- Defer loading + rendering mermaid until a diagram is near the viewport ---
    const diagrams = document.querySelectorAll<HTMLElement>('.mermaid');
    if (!diagrams.length) return;

    if ('IntersectionObserver' in window) {
      const observer = new IntersectionObserver(
        (entries, obs) => {
          if (entries.some((entry) => entry.isIntersecting)) {
            obs.disconnect();
            renderOnce(); // loads mermaid (once) and renders every diagram
          }
        },
        { rootMargin: '200px' }
      );
      diagrams.forEach((el) => observer.observe(el));
    } else {
      // Fallback: no IntersectionObserver support - load + render immediately.
      renderOnce();
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>
