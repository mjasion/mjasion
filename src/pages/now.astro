---
import BaseLayout from '../layouts/BaseLayout.astro';
import { author } from '../data/portfolio';

if (import.meta.env.PROD) {
  return new Response(null, { status: 404 });
}

const lastUpdated = new Date('2026-05-26');

const formatDate = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

const sections = [
  {
    heading: 'Work',
    body: `Senior SRE at NatWest Boxed in Warsaw. Supporting engineering teams across a system of 1000+ services — mostly incident response, observability work, and the quiet improvements that keep on-call calm.`,
  },
  {
    heading: 'Learning',
    body: `Going deeper on agentic systems after wrapping up AI_devs 3: Agents. Currently playing with LLM-driven incident triage — can a model usefully pre-summarise an alert before a human looks at it?`,
  },
  {
    heading: 'Building',
    body: `Slowly refreshing this blog — new About, new CV, this page. Long-term goal is to publish more about the day-to-day of running large fleets of services.`,
  },
  {
    heading: 'Reading',
    body: `Working through "Observability Engineering" (Majors, Fong-Jones, Miranda) again — it lands differently when the system you operate has four digits of services.`,
  },
];
---

<BaseLayout
  title="Now"
  description={`What ${author.name} is focused on right now — work, learning, and side projects.`}
>
  <Fragment slot="head">
    <link rel="canonical" href="https://mjasion.pl/now/" />
  </Fragment>

  <div class="mx-auto max-w-3xl px-4 py-12 space-y-8">

    <!-- Header -->
    <section class="rounded-3xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900 p-8 shadow-bento">
      <h1 class="text-3xl font-bold tracking-tight">Now</h1>
      <p class="mt-3 text-gray-600 dark:text-gray-300 leading-relaxed">
        A snapshot of what I'm focused on right now — inspired by Derek Sivers' <a href="https://nownownow.com/about" class="text-accent-600 dark:text-accent-400 hover:underline">/now</a> page idea.
      </p>
      <p class="mt-2 text-xs text-gray-500 dark:text-gray-400">
        Last updated <time datetime={lastUpdated.toISOString()}>{formatDate(lastUpdated)}</time>
      </p>
    </section>

    <!-- Sections -->
    {sections.map((s) => (
      <section class="rounded-2xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900 p-6 shadow-bento">
        <h2 class="text-lg font-semibold">{s.heading}</h2>
        <p class="mt-2 text-gray-600 dark:text-gray-300 leading-relaxed">
          {s.body}
        </p>
      </section>
    ))}

    <!-- Footer note -->
    <section class="rounded-2xl border border-dashed border-gray-300 dark:border-gray-700 p-6 text-sm text-gray-500 dark:text-gray-400">
      Want to compare notes on incident response, observability, or running large fleets? <a href="/about/" class="text-accent-600 dark:text-accent-400 hover:underline">Reach out</a>.
    </section>
  </div>
</BaseLayout>
